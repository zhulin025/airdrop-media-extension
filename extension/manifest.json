{
  "manifest_version": 3,
  "name": "AirDrop Media",
  "description": "Download page media or capture the visible tab, then open the macOS AirDrop panel.",
  "version": "0.2.0",
  "permissions": [
    "contextMenus",
    "downloads",
    "nativeMessaging",
    "notifications",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "截图并用 AirDrop 发送",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "minimum_chrome_version": "109"
}
